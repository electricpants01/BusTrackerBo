---
interface Props {
	showNav?: boolean;
}

const { showNav = true } = Astro.props;
---

<header class="border-b border-border bg-bg-card">
	<div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 md:px-6">
		<a href={import.meta.env.BASE_URL} class="flex items-center gap-2 text-lg font-semibold text-text">
			<span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-primary text-white">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
					<path fill="currentColor" d="M4 16c0 .88.39 1.67 1 2.22V20c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h8v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1.78c.61-.55 1-1.34 1-2.22V6c0-3.5-3.58-4-8-4S4 2.5 4 6v10zm3.5 1c-.83 0-1.5-.67-1.5-1.5S6.67 14 7.5 14s1.5.67 1.5 1.5S8.33 17 7.5 17zm9 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm1.5-6H6V6h12v5z"/>
				</svg>
			</span>
			<span>BusTracker<span class="text-primary">Bo</span></span>
		</a>

		{
			showNav && (
				<nav class="hidden items-center gap-4 text-sm text-text-muted sm:flex">
					<span>Español</span>
					<span>BOB</span>
					<a href="#" class="hover:text-text">
						Ayuda
					</a>
				</nav>
			)
		}
	</div>
</header>
