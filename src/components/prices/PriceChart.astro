---
import Card from '../ui/Card.astro';
import {
	CHART_COLORS,
	CHART_DEFAULTS,
	OPERATOR_LINE_COLORS,
} from '../../lib/chart-config';
import type { DailyPrice } from '../../lib/prices';

interface Props {
	history: DailyPrice[];
	highlightDate?: string;
	title?: string;
}

const {
	history,
	highlightDate,
	title = 'Historial de precios',
} = Astro.props;

const hasData = history.length > 0;
const chartId = 'price-history-chart';

const labels = history.map((day) =>
	new Intl.DateTimeFormat('es-BO', { day: 'numeric', month: 'short' }).format(
		new Date(`${day.date}T12:00:00`),
	),
);

const highlightIndex = highlightDate ? history.findIndex((day) => day.date === highlightDate) : -1;

const operatorNames = [
	...new Set(history.flatMap((day) => day.operators.map((operator) => operator.name))),
].sort((a, b) => a.localeCompare(b, 'es'));

const datasets = operatorNames.map((name, index) => {
	const color = OPERATOR_LINE_COLORS[index % OPERATOR_LINE_COLORS.length];
	return {
		label: name,
		color,
		data: history.map((day) => {
			const match = day.operators.find((operator) => operator.name === name);
			return match?.price ?? null;
		}),
	};
});

const chartPayload = JSON.stringify({
	labels,
	datasets,
	highlightIndex,
	colors: CHART_COLORS,
	prefix: CHART_DEFAULTS.currencyPrefix,
});
---

<Card class="overflow-hidden">
	<div class="mb-4 flex items-center justify-between gap-4">
		<h2 class="text-lg font-semibold text-text">{title}</h2>
		{
			hasData && (
				<p class="text-sm text-text-muted">
					Precio por operador · {CHART_DEFAULTS.currencyPrefix}
				</p>
			)
		}
	</div>

	{
		hasData ? (
			<div class="relative h-72 md:h-96">
				<canvas
					id={chartId}
					data-chart={chartPayload}
					aria-label="Gráfico de historial de precios por operador"
				/>
			</div>
		) : (
			<div class="flex h-60 items-center justify-center rounded-lg border border-dashed border-border bg-bg-page text-center text-text-muted md:h-80">
				<p>No hay datos para esta ruta. Vuelve mañana.</p>
			</div>
		)
	}
</Card>

{hasData && <script src="./price-chart.client.ts" />}
