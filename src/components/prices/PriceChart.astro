---
import Card from '../ui/Card.astro';
import { CHART_COLORS, CHART_DEFAULTS } from '../../lib/chart-config';
import type { DailyPrice } from '../../lib/prices';

interface Props {
	history: DailyPrice[];
	highlightDate?: string;
	title?: string;
}

const {
	history,
	highlightDate,
	title = 'Historial de precios',
} = Astro.props;

const hasData = history.length > 0;
const chartId = 'price-history-chart';

const labels = history.map((day) =>
	new Intl.DateTimeFormat('es-BO', { day: 'numeric', month: 'short' }).format(
		new Date(`${day.date}T12:00:00`),
	),
);
const values = history.map((day) => day.minPrice);
const highlightIndex = highlightDate ? history.findIndex((day) => day.date === highlightDate) : -1;
---

<Card class="overflow-hidden">
	<div class="mb-4 flex items-center justify-between gap-4">
		<h2 class="text-lg font-semibold text-text">{title}</h2>
		{
			hasData && (
				<p class="text-sm text-text-muted">
					Precio mínimo por día · {CHART_DEFAULTS.currencyPrefix}
				</p>
			)
		}
	</div>

	{
		hasData ? (
			<div class="relative h-60 md:h-80">
				<canvas id={chartId} aria-label="Gráfico de historial de precios" />
			</div>
		) : (
			<div class="flex h-60 items-center justify-center rounded-lg border border-dashed border-border bg-bg-page text-center text-text-muted md:h-80">
				<p>No hay datos para esta ruta. Vuelve mañana.</p>
			</div>
		)
	}
</Card>

{
	hasData && (
		<script define:vars={{ chartId, labels, values, highlightIndex, colors: CHART_COLORS, prefix: CHART_DEFAULTS.currencyPrefix }}>
			import { Chart } from 'chart.js/auto';

			const canvas = document.getElementById(chartId);
			if (!(canvas instanceof HTMLCanvasElement)) throw new Error('Chart canvas not found');

			const pointRadius = values.map((_, index) => (index === highlightIndex ? 6 : 3));
			const pointBackgroundColor = values.map((_, index) =>
				index === highlightIndex ? colors.highlight : colors.point,
			);

			new Chart(canvas, {
				type: 'line',
				data: {
					labels,
					datasets: [
						{
							label: 'Precio mínimo',
							data: values,
							borderColor: colors.line,
							backgroundColor: colors.fill,
							fill: true,
							tension: 0.35,
							pointRadius,
							pointBackgroundColor,
							pointBorderColor: '#ffffff',
							pointBorderWidth: 2,
						},
					],
				},
				options: {
					responsive: true,
					maintainAspectRatio: false,
					plugins: {
						legend: { display: false },
						tooltip: {
							callbacks: {
								label(context) {
									const value = context.parsed.y;
									return `${prefix} ${value.toLocaleString('es-BO')}`;
								},
							},
						},
					},
					scales: {
						x: {
							grid: { color: colors.grid },
							ticks: { color: colors.text },
						},
						y: {
							grid: { color: colors.grid },
							ticks: {
								color: colors.text,
								callback(value) {
									return `${prefix} ${value}`;
								},
							},
						},
					},
				},
			});
		</script>
	)
}
