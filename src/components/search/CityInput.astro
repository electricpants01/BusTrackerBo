---
import { CITIES, getCityName } from '../../lib/cities';

interface Props {
	label: string;
	name: string;
	value?: string;
	placeholder?: string;
}

const {
	label,
	name,
	value = '',
	placeholder = 'Ciudad',
} = Astro.props;
---

<label class="flex min-w-0 flex-1 flex-col gap-1 px-4 py-3">
	<span class="text-xs font-medium text-text-muted">{label}</span>
	<input
		type="text"
		value={getCityName(value) || value}
		list={`${name}-cities`}
		placeholder={placeholder}
		data-slug-input={name}
		class="w-full border-0 bg-transparent p-0 text-base text-text outline-none placeholder:text-text-muted"
		required
	/>
	<input type="hidden" name={name} value={value} data-slug-hidden={name} />
	<datalist id={`${name}-cities`}>
		{CITIES.map((city) => (
			<option value={city.name} data-slug={city.slug} />
		))}
	</datalist>
</label>

<script define:vars={{ name, cities: CITIES }}>
	const textInput = document.querySelector(`[data-slug-input="${name}"]`);
	const hiddenInput = document.querySelector(`[data-slug-hidden="${name}"]`);
	const nameToSlug = new Map(cities.map((city) => [city.name, city.slug]));

	function syncSlug() {
		if (!textInput || !hiddenInput) return;
		const slug = nameToSlug.get(textInput.value.trim());
		hiddenInput.value = slug ?? textInput.value.trim().toLowerCase().replace(/\s+/g, '-');
	}

	textInput?.addEventListener('change', syncSlug);
	textInput?.addEventListener('blur', syncSlug);
</script>
