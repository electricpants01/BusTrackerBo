---
interface Props {
	name?: string;
	value?: string;
	label?: string;
}

const {
	name = 'date',
	value = new Date().toISOString().slice(0, 10),
	label = 'Fecha',
} = Astro.props;
---

<label class="flex min-w-0 flex-1 flex-col gap-1 px-4 py-3">
	<span class="text-xs font-medium text-text-muted">{label}</span>
	<input
		type="date"
		name={name}
		value={value}
		class="w-full border-0 bg-transparent p-0 text-base text-text outline-none"
		required
	/>
</label>
