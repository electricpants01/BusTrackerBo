---
interface Props {
	message: string;
	dismissible?: boolean;
}

const { message, dismissible = true } = Astro.props;
---

<div
	class="alert-banner mb-6 flex items-start gap-3 rounded-lg bg-banner-info px-4 py-3 text-sm text-text"
	role="status"
>
	<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" class="mt-0.5 shrink-0 text-primary" aria-hidden="true">
		<path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
	</svg>
	<p class="flex-1">{message}</p>
	{
		dismissible && (
			<button
				type="button"
				class="alert-dismiss shrink-0 rounded p-1 text-text-muted hover:text-text"
				aria-label="Cerrar"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
					<path fill="currentColor" d="M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
				</svg>
			</button>
		)
	}
</div>

{
	dismissible && (
		<script>
			document.querySelectorAll('.alert-dismiss').forEach((button) => {
				button.addEventListener('click', () => {
					button.closest('.alert-banner')?.remove();
				});
			});
		</script>
	)
}
